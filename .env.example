# Copy to .env and adjust for your environment. docker-compose.yml falls back to
# root123 if MYSQL_ROOT_PASSWORD is unset, so this file is optional for local dev.
MYSQL_ROOT_PASSWORD=root123

# Master password protecting the Elytron credential store (cli/configure-datasource-full.cli)
# that holds MYSQL_ROOT_PASSWORD encrypted at rest. Change this for anything beyond local dev.
CS_MASTER_PASSWORD=changeit

# WildFly management console (http://localhost:9990) admin user.
# Leave WILDFLY_ADMIN_PASSWORD unset to skip creating the user entirely.
WILDFLY_ADMIN_USER=admin
WILDFLY_ADMIN_PASSWORD=
